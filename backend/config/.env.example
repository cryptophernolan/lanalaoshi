# Binance — LUÔN bắt đầu với testnet
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Dry run = không thực sự đặt lệnh, chỉ log
DRY_RUN=true

# CryptoPanic — đăng ký free tại https://cryptopanic.com/developers/api/
# Không có key vẫn chạy được (public endpoint, ít data hơn)
CRYPTOPANIC_API_KEY=

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Twitter/X (optional - tắt mặc định)
TWITTER_BEARER_TOKEN=

# Database
DB_URL=sqlite:///./data/bot.db
